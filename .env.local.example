# TMDB — API Read Access Token (Bearer token from themoviedb.org/settings/api)
TMDB_API_TOKEN=your_tmdb_bearer_token_here

# Anthropic — from console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Watchmode (optional) — real per-streamer deep links on the film page.
# Get a free key at api.watchmode.com (1000 req/mo free tier). When unset, the
# "Where to watch" section falls back to TMDB's single JustWatch link.
WATCHMODE_API_KEY=your_watchmode_api_key_here

# Region for "Where to watch" provider data (ISO country code). Defaults to GB.
NEXT_PUBLIC_WATCH_REGION=GB

# Supabase — from supabase.com → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service-role key (Settings → API → service_role). Server-only — NEVER expose to
# the client. Powers the admin dashboard (listing/banning/deleting users).
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Comma-separated allowlist of admin emails. These users can reach /admin.
ADMIN_EMAILS=you@yourdomain.com

# Canonical site URL — used for magic-link redirects so emails always point at
# production (no trailing slash). Leave unset to use the current browser origin.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Sign-in notifications via Resend (optional). When all three are set, an email
# is sent to SIGNIN_NOTIFY_TO each time a user signs in. SIGNIN_NOTIFY_FROM must
# be on a domain verified in Resend. Leave unset to disable.
RESEND_API_KEY=re_your_resend_api_key_here
SIGNIN_NOTIFY_TO=you@yourdomain.com
SIGNIN_NOTIFY_FROM=noreply@yourdomain.com
